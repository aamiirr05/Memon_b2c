model EnquiryUmrah {
  enquiry_id     String   @id @default(uuid())
  user_id        String?
  salutation     String
  first_name     String
  last_name      String
  email          String
  package_type   String
  package_name   String
  contact        String
  traveller_date String
  total_adults   Int      @default(0)
  total_children Int      @default(0)
  total_infants  Int      @default(0)
  status         Status   @default(Pending)
  created_at     DateTime @default(now())
  user           User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

model EnquiryVisa {
  enquiry_id   String   @id @default(uuid())
  user_id      String?
  salutation   String
  first_name   String
  last_name    String
  email        String
  contact      String
  visa_country String
  visa_type    String
  status       Status   @default(Pending)
  created_at   DateTime @default(now())
  user         User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

model EnquiryForex {
  enquiry_id      String   @id @default(uuid())
  user_id         String?
  salutation      String
  first_name      String
  last_name       String
  email           String
  contact         String
  amount_required Decimal
  country         String
  address         String
  status          Status   @default(Pending)
  created_at      DateTime @default(now())
  user            User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

model EnquiryContact {
  enquiry_id String   @id @default(uuid())
  user_id    String?
  salutation String
  first_name String
  last_name  String
  email      String
  contact    String
  message    String
  status     Status   @default(Pending)
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

model EnquiryHotel {
  enquiry_id         String   @id @default(uuid())
  user_id            String?
  full_name          String
  contact            String
  email              String
  check_in_date      String
  check_out_date     String
  number_of_nights   Int
  number_of_rooms    Int
  room_type          String
  meal_plan          String
  number_of_adults   Int      @default(0)
  number_of_children Int      @default(0)
  special_request    String?
  status             Status   @default(Pending)
  created_at         DateTime @default(now())
  user               User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

model EnquiryHoliday {
  enquiry_id               String   @id @default(uuid())
  user_id                  String?
  full_name                String
  contact                  String
  email                    String
  nationlaity              String
  preferred_date           String
  number_of_nights         Int
  number_of_adults         Int      @default(0)
  number_of_children       Int      @default(0)
  preferred_departure_city String
  status                   Status   @default(Pending)
  created_at               DateTime @default(now())
  user                     User?    @relation(fields: [user_id], references: [registration_id], onDelete: Cascade)
}

enum Status {
  Pending
  Approved
  Rejected
}
