model Visa {
  visa_id              String   @id @default(uuid())
  admin                Admin    @relation(fields: [admin_id], references: [admin_id], onDelete: Cascade)
  admin_id             String
  visa_country         String
  visa_type            String
  visa_image           Json
  price                Int
  description          String
  processing_time      String
  validity             String
  stay_period          Int
  entry                String
  document_requirement Json
  basic_requirement    String[]
  term_condition       String[]
  booking_terms        String[]
  cancellation_policy  String[]
  created_at           DateTime @default(now())
}
