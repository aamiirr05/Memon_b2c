model UmrahPackage {
  package_id       String              @id @default(uuid())
  admin            Admin               @relation(fields: [admin_id], references: [admin_id], onDelete: Cascade)
  admin_id         String
  package_name     String              @db.VarChar(200)
  package_image    Json
  package_type     String              @db.VarChar(100)
  description      String
  group_dates      String
  total_days       Int
  total_nights     Int
  mak_hotel_name   String              @db.VarChar(200)
  mak_hotel_images Json
  med_hotel_name   String              @db.VarChar(200)
  med_hotel_images Json
  created_at       DateTime            @default(now())
  prices           UmrahPackagePrice[]
}

model UmrahPackagePrice {
  price_id                String       @id @default(uuid())
  package                 UmrahPackage @relation(fields: [package_id], references: [package_id], onDelete: Cascade)
  package_id              String
  quint_price             Decimal
  quad_price              Decimal
  triple_price            Decimal
  double_price            Decimal
  child_without_bed_price Decimal
  infant_price            Decimal
  created_at              DateTime     @default(now())
}
