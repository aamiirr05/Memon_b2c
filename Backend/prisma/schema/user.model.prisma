model User {
    registration_id String           @id @default(uuid())
    salutation      String           @db.VarChar(10)
    first_name      String           @db.VarChar(50)
    last_name       String           @db.VarChar(50)
    email           String           @unique @db.VarChar(100)
    contact         String           @db.VarChar(15)
    password        String           @db.VarChar(100)
    created_at      DateTime         @default(now())
    refresh_token   String?
    enquiry_umrah   EnquiryUmrah[]
    enquiry_visa    EnquiryVisa[]
    enquiry_forex   EnquiryForex[]
    enquiry_contact EnquiryContact[]
}
